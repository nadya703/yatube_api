# =============================================
# ПЕРЕМЕННЫЕ — задай свои данные
# =============================================
@baseUrl = http://127.0.0.1:8000
@username = orbuzik
@password = qwerty12345

# После получения токена вставь его сюда вручную:
@token = ВСТАВЬ_ТОКЕН_СЮДА

# ID поста и комментария — вставляй после создания:
@post_id = 1
@comment_id = 1
@group_id = 1


### =============================================
### 1. АУТЕНТИФИКАЦИЯ — получить токен (POST)
### =============================================
POST {{baseUrl}}/api/v1/api-token-auth/
Content-Type: application/json

{
    "username": "{{username}}",
    "password": "{{password}}"
}


### =============================================
### 2. ПОСТЫ — получить список (GET)
### =============================================
GET {{baseUrl}}/api/v1/posts/
Authorization: Token {{token}}


### =============================================
### 3. ПОСТЫ — создать новый пост (POST)
### =============================================
POST {{baseUrl}}/api/v1/posts/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "Вечером собрались в редакции «Русской мысли».",
    "group": null
}


### =============================================
### 4. ПОСТЫ — получить пост по id (GET)
### =============================================
GET {{baseUrl}}/api/v1/posts/{{post_id}}/
Authorization: Token {{token}}


### =============================================
### 5. ПОСТЫ — обновить пост через PATCH
### =============================================
PATCH {{baseUrl}}/api/v1/posts/{{post_id}}/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "Обновлённый текст через PATCH",
    "group": {{group_id}}
}


### =============================================
### 6. ПОСТЫ — обновить пост через PUT
### =============================================
PUT {{baseUrl}}/api/v1/posts/{{post_id}}/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "Полная замена текста через PUT",
    "group": null
}


### =============================================
### 7. ПОСТЫ — удалить пост (DELETE)
### =============================================
DELETE {{baseUrl}}/api/v1/posts/{{post_id}}/
Authorization: Token {{token}}


### =============================================
### 8. ГРУППЫ — получить список (GET)
### =============================================
GET {{baseUrl}}/api/v1/groups/
Authorization: Token {{token}}


### =============================================
### 9. ГРУППЫ — получить группу по id (GET)
### =============================================
GET {{baseUrl}}/api/v1/groups/{{group_id}}/
Authorization: Token {{token}}


### =============================================
### 10. КОММЕНТАРИИ — получить список (GET)
### =============================================
GET {{baseUrl}}/api/v1/posts/{{post_id}}/comments/
Authorization: Token {{token}}


### =============================================
### 11. КОММЕНТАРИИ — создать комментарий (POST)
### =============================================
POST {{baseUrl}}/api/v1/posts/{{post_id}}/comments/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "тест тест"
}


### =============================================
### 12. КОММЕНТАРИИ — получить комментарий (GET)
### =============================================
GET {{baseUrl}}/api/v1/posts/{{post_id}}/comments/{{comment_id}}/
Authorization: Token {{token}}


### =============================================
### 13. КОММЕНТАРИИ — обновить через PATCH
### =============================================
PATCH {{baseUrl}}/api/v1/posts/{{post_id}}/comments/{{comment_id}}/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "Обновлённый комментарий"
}


### =============================================
### 14. КОММЕНТАРИИ — обновить через PUT
### =============================================
PUT {{baseUrl}}/api/v1/posts/{{post_id}}/comments/{{comment_id}}/
Authorization: Token {{token}}
Content-Type: application/json

{
    "text": "Полная замена комментария"
}


### =============================================
### 15. КОММЕНТАРИИ — удалить (DELETE)
### =============================================
DELETE {{baseUrl}}/api/v1/posts/{{post_id}}/comments/{{comment_id}}/
Authorization: Token {{token}}